## Aiven for OpenSearch
# From Aiven service "Connection information" (example format)
OPENSEARCH_URI="https://USER:PASSWORD@HOST:PORT"
OPENSEARCH_INDEX="lures"
# Optional: path to an Aiven project CA certificate file (PEM).
OPENSEARCH_CA_CERTS=""

## Vertex AI / Gemini
GCP_PROJECT_ID="your-gcp-project-id"
GCP_LOCATION="us-central1"
GEMINI_EMBED_MODEL="gemini-embedding-001"

## Embedding/vector config (must match your index mapping)
EMBED_DIM=3072

